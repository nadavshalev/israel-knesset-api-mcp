# ----- Database (PostgreSQL) -----
# Required — the server raises an error at startup if any of these are missing.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=my_app_user
POSTGRES_PASSWORD=changeme

# ----- MCP Server -----
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_ENDPOINT=/mcp

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=180

# ----- Response Limits -----
# Max characters in a JSON response before returning an error.
MAX_OUTPUT_TOKENS=50000
# Default and maximum number of results per paginated request.
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
# Max rows returned by a single detail sub-query (initiators, documents, stages, etc.)
MAX_DETAIL_ITEMS=200
# Max results per entity type in search_across.
SEARCH_ACROSS_TOP_N=5

# ----- Fuzzy Search -----
# Trigram similarity threshold for strict_word_similarity (0.0–1.0).
# Must match pg_trgm.strict_word_similarity_threshold GUC so GIN indexes are used.
FUZZY_TRGM_THRESHOLD=0.5

# ----- Connection Pool -----
POOL_MAX_CONN=10
POOL_HEALTH_INTERVAL=30   # seconds between pool liveness checks; 0 = disabled

# ----- Tool Timeout -----
# Max seconds a single MCP tool call may run before returning a timeout error.
# Set to 0 to disable.
MCP_TOOL_TIMEOUT=20

# ----- Logging -----
LOG_LEVEL=INFO
# Optional file path — when set, logs are written here in addition to stderr.
LOG_FILE=mcp_server.log

# ----- Updater Worker -----
# These are read by docker/updater-entrypoint.sh and the Python updater scripts.
# Run a data sync every N days at UPDATE_HOUR_IN_DAY:00 (container local time).
UPDATE_CYCLE_DAYS=1
UPDATE_HOUR_IN_DAY=22
# Run one sync immediately when the updater container starts.
UPDATE_RUN_ON_START=true

# ----- Israel Proxy -----
# HTTP proxy with an Israeli exit IP, used by the updater (--proxy flag).
# Leave empty for direct connection (dev/local).
ISRAEL_PROXY_URL=http://wireproxy-client.internal:8080
