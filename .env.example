# ----- Database (PostgreSQL) -----
POSTGRES_PATH=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=my_app_user
POSTGRES_PASSWORD=changeme

# ----- MCP Server -----
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_ENDPOINT=/mcp

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- Response Limits -----
MAX_OUTPUT_TOKENS=50_000
MAX_SEARCH_RESULTS=100
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
MAX_DETAIL_ITEMS=200

# Number of top results per entity type in search_across
SEARCH_ACROSS_TOP_N=5

# ----- Fuzzy Search -----
# Trigram similarity threshold for strict_word_similarity (0.0–1.0).
# Must match pg_trgm.strict_word_similarity_threshold GUC so GIN indexes are used.
FUZZY_TRGM_THRESHOLD=0.5

# ----- Cache -----
CACHE_MAX_MB=100
CACHE_TTL_SECONDS=300

# ----- Connection Pool -----
POOL_MAX_CONN=10

# ----- Tool Timeout -----
# Max seconds a single MCP tool call may run before returning a timeout error.
# Set to 0 to disable.
MCP_TOOL_TIMEOUT=5

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FILE="mcp_server.log"  # optional path; when set, logs also go to this file

# ----- Updater Worker -----
# Run update_all.py every N days at UPDATE_HOUR_IN_DAY:00 (container local time)
UPDATE_CYCLE_DAYS=1
# Hour in day for scheduled update (0-23)
UPDATE_HOUR_IN_DAY=3
# Run one update immediately when the updater container starts
UPDATE_RUN_ON_START=true

# ----- WireGuard VPN -----
WG_PRIVATE_KEY=changeme
WG_PUBLIC_KEY=changeme
WG_ENDPOINT=changeme:51820
WG_ADDRESS=10.2.0.2/32
WG_DNS=10.2.0.1