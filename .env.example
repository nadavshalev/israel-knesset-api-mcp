# ----- Database -----
DB_PATH=data.sqlite

# ----- MCP Server -----
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_ENDPOINT=/mcp

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- Response Limits -----
# Max characters in a JSON response before returning an error.
# Individual tool calls can override this with a max_results_size parameter.
MAX_RESULTS_SIZE=50000

# Number of top results per entity type in search_across
SEARCH_ACROSS_TOP_N=5
