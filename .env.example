# ----- Database (PostgreSQL) -----
POSTGRES_PATH=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=my_app_user
POSTGRES_PASSWORD=changeme

# ----- MCP Server -----
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_ENDPOINT=/mcp

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- Response Limits -----
# Max characters in a JSON response before returning an error.
# Individual tool calls can override this with a max_output_tokens parameter.
MAX_OUTPUT_TOKENS=50000

# Number of top results per entity type in search_across
SEARCH_ACROSS_TOP_N=5

# ----- Updater Worker -----
# Run update_all.py every N days at UPDATE_HOUR_IN_DAY:00 (container local time)
UPDATE_CYCLE_DAYS=1
# Hour in day for scheduled update (0-23)
UPDATE_HOUR_IN_DAY=3
# Run one update immediately when the updater container starts
UPDATE_RUN_ON_START=true
